{
  "model": "opus",
  "permission_mode": "bypassPermissions",
  "denyList": [
    "Bash(git reset --hard*)",
    "Bash(git clean*)",
    "Bash(rm -rf*)",
    "Bash(sudo *)",
    "Bash(*deploy-prod*)",
    "Bash(git commit --amend*)",
    "Bash(git stash drop*)",
    "Bash(git stash clear*)",
    "Bash(git rebase -i*)",
    "Bash(git branch -D*)",
    "Write(~/.claude/fleet/**/hooks/**)",
    "Edit(~/.claude/fleet/**/hooks/**)"
  ]
}
