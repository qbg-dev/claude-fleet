{
  "model": "opus",
  "permission_mode": "bypassPermissions",
  "denyList": [
    "Bash(git checkout main*)",
    "Bash(git merge*)",
    "Bash(git push*)",
    "Bash(git reset --hard*)",
    "Bash(git clean*)",
    "Bash(rm -rf*)",
    "Bash(sudo *)",
    "Edit",
    "Write(src/**)",
    "Write(data/**)"
  ]
}
