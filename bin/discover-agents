#!/usr/bin/env bash
# discover-agents — On-demand peer discovery for Claude Code agents.
# Usage: discover-agents [--busy-only] [--json]
#
# Call this when you need to coordinate with other agents.
# Not injected automatically — agents pull when they need it.
set -uo pipefail

source "$HOME/.claude-ops/lib/harness-jq.sh" 2>/dev/null || true
[ -f "$HOME/.claude-ops/control-plane.conf" ] && source "$HOME/.claude-ops/control-plane.conf"
AGENT_SNAPSHOT_LINES="${AGENT_SNAPSHOT_LINES:-8}"
PROCESS_DISCOVERY_MAX_CHILDREN="${PROCESS_DISCOVERY_MAX_CHILDREN:-5}"

BUSY_ONLY=false
JSON_OUT=false
while [[ $# -gt 0 ]]; do
  case "$1" in
    --busy-only) BUSY_ONLY=true; shift ;;
    --json)      JSON_OUT=true; shift ;;
    *) shift ;;
  esac
done

# Find own pane
OWN_PANE_ID=$(hook_find_own_pane 2>/dev/null || echo "")

agents=()
while IFS=$'\t' read -r ptarget ppid pane_id; do
  # Skip self
  [ -n "$OWN_PANE_ID" ] && [ "$pane_id" = "$OWN_PANE_ID" ] && continue

  # Check for claude process
  is_claude=false
  for cpid in $(pgrep -P "$ppid" 2>/dev/null | head -$PROCESS_DISCOVERY_MAX_CHILDREN); do
    ps -o command= -p "$cpid" 2>/dev/null | grep -q "^claude " && is_claude=true && break
  done
  $is_claude || continue

  # Snapshot for busy detection
  snap=$(tmux capture-pane -t "$pane_id" -p 2>/dev/null | grep -v '^[[:space:]]*$' | tail -$AGENT_SNAPSHOT_LINES)
  state="idle"
  echo "$snap" | grep -qE '(Thinking|Herding|Discombobulating|Processing|Reasoning|thought for)' && state="busy"

  # Skip idle if --busy-only
  [ "$BUSY_ONLY" = "true" ] && [ "$state" = "idle" ] && continue

  # Read pane registry metadata
  model=$(echo "$snap" | grep -oE '⚙️ [A-Za-z0-9. ]+' | tail -1 | sed 's/⚙️ //' || echo "?")
  harness="" task="" session_name=""
  _pane_data=$(pane_registry_read "$pane_id" 2>/dev/null || echo "{}")
  if [ -n "$_pane_data" ] && [ "$_pane_data" != "{}" ]; then
    harness=$(echo "$_pane_data" | jq -r '.harness // ""' 2>/dev/null || echo "")
    task=$(echo "$_pane_data" | jq -r '.display // ""' 2>/dev/null || echo "")
    session_name=$(echo "$_pane_data" | jq -r '.session_name // ""' 2>/dev/null || echo "")
  fi

  if [ "$JSON_OUT" = "true" ]; then
    agents+=("$(jq -n \
      --arg pane "$ptarget" \
      --arg pane_id "$pane_id" \
      --arg state "$state" \
      --arg model "${model:-?}" \
      --arg harness "$harness" \
      --arg task "$task" \
      --arg session "$session_name" \
      '{pane:$pane, pane_id:$pane_id, state:$state, model:$model, harness:$harness, task:$task, session:$session}')")
  else
    detail="${task:-no status}"
    [ -n "$session_name" ] && detail="${detail} [${session_name}]"
    agents+=("${ptarget} [${model:-?}] (${state}) ${harness:+${harness}: }${detail}")
  fi
done < <(tmux list-panes -a -F $'#{session_name}:#{window_index}.#{pane_index}\t#{pane_pid}\t#{pane_id}' 2>/dev/null)

if [ ${#agents[@]} -eq 0 ]; then
  if [ "$JSON_OUT" = "true" ]; then
    echo "[]"
  else
    echo "No other Claude agents found."
  fi
elif [ "$JSON_OUT" = "true" ]; then
  printf '%s\n' "${agents[@]}" | jq -s '.'
else
  echo "${#agents[@]} agents found:"
  for a in "${agents[@]}"; do
    echo "  - $a"
  done
fi
