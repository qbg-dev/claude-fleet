{
  "_comment": "Canonical hook registry. setup-hooks.sh reads this to install into ~/.claude/settings.json. lint-hooks.sh reads this to verify installation.",
  "hooks": [
    {
      "id": "worker-session-register",
      "event": "UserPromptSubmit",
      "path": "~/.claude-ops/hooks/publishers/worker-session-register.sh",
      "required": true,
      "category": "core",
      "description": "Registers worker pane in fleet on each prompt submit"
    },
    {
      "id": "snippet-injector",
      "event": "UserPromptSubmit",
      "path": "~/.claude-ops/plugins/claude-context-orchestrator/scripts/snippets/snippet_injector.py",
      "runner": "python3",
      "matcher": ".*",
      "required": false,
      "category": "plugin",
      "description": "Injects contextual snippets into prompts"
    },
    {
      "id": "prompt-publisher",
      "event": "UserPromptSubmit",
      "path": "~/.claude-ops/hooks/publishers/prompt-publisher.sh",
      "required": true,
      "category": "core",
      "description": "Publishes prompt events to event bus (watchdog, coordinator inbox)"
    },
    {
      "id": "prompt-echo-deferred",
      "event": "UserPromptSubmit",
      "path": "~/.claude-ops/hooks/publishers/prompt-echo-deferred.sh",
      "required": false,
      "category": "user",
      "description": "Deferred echo chain — feeds queued prompts from stop-echo.sh"
    },
    {
      "id": "pii-firewall",
      "event": "PreToolUse",
      "path": "{PROJECT_ROOT}/.claude/hooks/pii-firewall.sh",
      "required": false,
      "category": "project",
      "description": "Blocks direct access to customer conversation content (PIPL compliance). Project-specific."
    },
    {
      "id": "tool-policy-gate",
      "event": "PreToolUse",
      "path": "~/.claude-ops/hooks/gates/tool-policy-gate.sh",
      "required": true,
      "category": "core",
      "description": "Enforces per-worker tool permission policies (disallowedTools)"
    },
    {
      "id": "git-safety-gate",
      "event": "PreToolUse",
      "path": "~/.claude-ops/hooks/gates/git-safety-gate.sh",
      "required": true,
      "category": "core",
      "description": "Blocks dangerous git operations (amend, branch -D, rebase -i) and enforces worker/* branch naming"
    },
    {
      "id": "pre-tool-context-injector",
      "event": "PreToolUse",
      "path": "~/.claude-ops/hooks/interceptors/pre-tool-context-injector.sh",
      "required": true,
      "category": "core",
      "description": "Injects contextual hints before tool execution (policy, inbox, phase)"
    },
    {
      "id": "liveness-heartbeat-post",
      "event": "PostToolUse",
      "path": "~/.claude-ops/hooks/publishers/liveness-heartbeat.sh",
      "required": true,
      "category": "core",
      "description": "Touches liveness timestamp on every tool call for watchdog stuck detection"
    },
    {
      "id": "liveness-heartbeat-prompt",
      "event": "UserPromptSubmit",
      "path": "~/.claude-ops/hooks/publishers/liveness-heartbeat.sh",
      "required": true,
      "category": "core",
      "description": "Touches liveness timestamp on every prompt for watchdog stuck detection"
    },
    {
      "id": "subagent-start",
      "event": "SubagentStart",
      "path": "~/.claude-ops/hooks/publishers/subagent-lifecycle.sh",
      "required": true,
      "category": "core",
      "description": "Tracks subagent lifecycle for resource management"
    },
    {
      "id": "subagent-stop",
      "event": "SubagentStop",
      "path": "~/.claude-ops/hooks/publishers/subagent-lifecycle.sh",
      "required": true,
      "category": "core",
      "description": "Tracks subagent lifecycle for resource management"
    },
    {
      "id": "pre-compact",
      "event": "PreCompact",
      "path": "~/.claude-ops/scripts/pre-compact.sh",
      "timeout": 5000,
      "required": true,
      "category": "core",
      "description": "Re-injects seed template + worker state before context compaction"
    },
    {
      "id": "liveness-heartbeat-stop",
      "event": "Stop",
      "path": "~/.claude-ops/hooks/publishers/liveness-heartbeat.sh",
      "required": true,
      "category": "core",
      "description": "Touches liveness timestamp on stop for watchdog stuck detection"
    },
    {
      "id": "stop-worker-dispatch",
      "event": "Stop",
      "path": "~/.claude-ops/hooks/gates/stop-worker-dispatch.sh",
      "required": true,
      "category": "core",
      "description": "Routes worker sessions — blocks until tasks complete"
    },
    {
      "id": "stop-inbox-drain",
      "event": "Stop",
      "path": "~/.claude-ops/hooks/gates/stop-inbox-drain.sh",
      "required": true,
      "category": "core",
      "description": "Blocks stopping if unread inbox messages or pending ACKs exist"
    },
    {
      "id": "stop-echo",
      "event": "Stop",
      "path": "~/.claude-ops/hooks/publishers/stop-echo.sh",
      "required": false,
      "category": "user",
      "description": "Echo chain support — pops queued items and re-injects as block reasons"
    },

