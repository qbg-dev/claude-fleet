    },
    {
      "id": "universal-logger-worktree-remove",
      "event": "WorktreeRemove",
      "path": "~/.claude-ops/hooks/publishers/universal-logger.sh",
      "required": true,
      "category": "core",
      "description": "Log WorktreeRemove to event bus"
    },

    {"_comment": "── Dynamic hook dispatcher (ALL events) ──"},

    {
