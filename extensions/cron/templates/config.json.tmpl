{
  "tick_interval": "5m",
  "coherency_review_every": 4,
  "model": "opus[1m]",
  "phases": {
    "plan": {
      "explorer_dir": "cron/phases/explorers/",
      "output_format": "Finding[]",
      "proceed_when_pct": 80,
      "min_explorers": 8,
      "default_explorers": 15,
      "swarm_threshold": 3,
      "swarm_size": 20
    },
    "execute": {
      "isolation": "worktree",
      "model": "opus[1m]"
    },
    "reflect": {
      "test_suites": ["{{TEST_COMMANDS}}"],
      "auto_deploy": false,
      "auto_promote_on_coherency": true,
      "push_after_commit": true
    }
  },
  "anti_stagnation": {
    "min_commits_per_tick": 1,
    "ticks_without_findings_trigger_swarm": 3,
    "carry_forward_priority_elevation": true,
    "green_means_too_narrow": true,
    "feature_finding_agents_when_stuck": 10
  }
}
